<Window x:Class="Journalx3Piska.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Journalx3Piska.ViewModels"
        xmlns:views="clr-namespace:Journalx3Piska.View"
        Title="Журнал" Height="500" Width="900">

    <Window.Resources>

        <!-- Связка ViewModel → View -->
        <DataTemplate DataType="{x:Type vm:GradesViewModel}">
            <views:GradesView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SubjectsViewModel}">
            <views:SubjectsView/>
        </DataTemplate>

    </Window.Resources>

    <DockPanel>

        <StackPanel Orientation="Horizontal"
                    DockPanel.Dock="Top"
                    Height="50">

            <Button Content="Оценки"
                    Command="{Binding ShowGradesCommand}" Width="88"/>
        </StackPanel>

        <ContentControl Content="{Binding CurrentViewModel}"/>

    </DockPanel>
</Window>