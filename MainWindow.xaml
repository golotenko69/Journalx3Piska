<Window x:Class="Journalx3Piska.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Journalx3Piska.ViewModels"
        xmlns:views="clr-namespace:Journalx3Piska.View"
        Title="Журнал"
        Height="800" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#F5F6FA">

    <!-- 🎨 Стили -->
    <Window.Resources>

        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="10,0"/>
            <Setter Property="Cursor" Value="Hand"/>

            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#FFD580"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ViewModel → View -->
        <DataTemplate DataType="{x:Type vm:GradesViewModel}">
            <views:GradesView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:SubjectsViewModel}">
            <views:SubjectsView/>
        </DataTemplate>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <!-- 🔷 HEADER -->
        <Grid Background="#4E6A91" Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Левая часть -->
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="20,0">

                <Button Content="🏠"
                        Style="{StaticResource NavButton}"
                        Command="{Binding ShowHomeCommand}"/>

                <Button Content="Занятия"
                        Style="{StaticResource NavButton}"
                        Command="{Binding ShowStudentsCommand}"/>

                <Button Content="Оценки"
                        Style="{StaticResource NavButton}"
                        Command="{Binding ShowGradesCommand}"/>

                <Button Content="Предметы"
                        Style="{StaticResource NavButton}"
                        Command="{Binding ShowSubjectsCommand}"/>

                <Button Content="Отчёты"
                        Style="{StaticResource NavButton}"
                        Command="{Binding ShowReportsCommand}"/>
            </StackPanel>

            <!-- Правая часть -->
            <StackPanel Orientation="Horizontal"
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        Margin="0,0,20,0">

                <ToggleButton Content="🌙"
                              Width="40"
                              Height="30"
                              Margin="10,0"
                              Command="{Binding ToggleThemeCommand}"/>

                <Button Content="Выход"
                        Background="#B00020"
                        Foreground="White"
                        BorderThickness="0"
                        Padding="10,5"
                        Command="{Binding ExitCommand}"/>
            </StackPanel>
        </Grid>

        <!-- 🔽 КОНТЕНТ -->
        <ContentControl Grid.Row="1"
                        Content="{Binding CurrentViewModel}"/>

    </Grid>
</Window>