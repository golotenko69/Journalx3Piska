<UserControl x:Class="Journalx3Piska.View.SubjectsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F6FA">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

        <!-- DataGrid -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#F7F9FC"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="RowHeight" Value="40"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <!-- Заголовки -->
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F0F6FF"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10"/>
        </Style>

        <!-- Ячейки -->
        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- Строки -->
        <Style TargetType="DataGridRow">
            <Setter Property="BorderThickness" Value="0"/>

            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EAF2FF"/>
                </Trigger>

                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#D6EAF8"/>
                    <Setter Property="Foreground" Value="Black"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </UserControl.Resources>

    <!-- ГЛАВНЫЙ КОНТЕЙНЕР -->
    <Grid>

        <!-- ОСНОВНОЙ КОНТЕНТ -->
        <Grid Margin="20">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <TextBlock Grid.Row="0"
                       Text="Предметы"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="#2C3E50"
                       Margin="0,0,0,10"/>

            <!-- 🔥 КНОПКИ -->
            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        Margin="0,0,0,15">

                <Button Content="Добавить предмет"
                        Width="180"
                        Height="35"
                        Margin="0,0,10,0"
                        Background="#4A90E2"
                        Foreground="White"
                        BorderThickness="0"
                        Command="{Binding OpenDialogCommand}"/>

                <Button Content="Удалить предмет"
                        Width="140"
                        Height="35"
                        Background="#E74C3C"
                        Foreground="White"
                        BorderThickness="0"
                        Command="{Binding DeleteSubjectCommand}"/>
            </StackPanel>

            <!-- Таблица -->
            <Border Grid.Row="2"
                    Background="White"
                    CornerRadius="12"
                    Padding="15">

                <DataGrid ItemsSource="{Binding Subjects}"
                          SelectedItem="{Binding SelectedSubject}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          SelectionMode="Single">

                    <DataGrid.Columns>

                        <!-- ID -->
                        <DataGridTextColumn Header="ID"
                                            Binding="{Binding SubjectID}"
                                            Width="60">

                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="TextAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- Название -->
                        <DataGridTextColumn Header="Название"
                                            Binding="{Binding SubjectName}"
                                            Width="*">

                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="10,0,0,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- Преподаватель -->
                        <DataGridTextColumn Header="Преподаватель"
                                            Binding="{Binding Teacher.FullName}"
                                            Width="*">

                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="10,0,0,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                    </DataGrid.Columns>

                </DataGrid>
            </Border>

        </Grid>

        <!-- 🔥 ДИАЛОГ -->
        <Grid Background="#80000000"
              Visibility="{Binding IsDialogOpen, Converter={StaticResource BoolToVisibility}}"
              Panel.ZIndex="100">

            <Border Width="400"
                    Padding="20"
                    Background="White"
                    CornerRadius="12"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">

                <StackPanel>

                    <TextBlock Text="Добавить предмет"
                               FontSize="18"
                               FontWeight="Bold"
                               Margin="0 0 0 15"/>

                    <!-- Название -->
                    <TextBlock Text="Название"/>

                    <TextBlock Text="(Выберите или введите название)"
                    FontSize="10"
                    Foreground="Gray"
                    Margin="0,0,0,3"/>

                    <ComboBox ItemsSource="{Binding Subjects}"
                    DisplayMemberPath="SubjectName"
                    SelectedItem="{Binding SelectedSubjectForAdd}"
                    IsEditable="True"
                    IsTextSearchEnabled="True"
                    StaysOpenOnEdit="True"
                    Text="{Binding NewSubjectName, UpdateSourceTrigger=PropertyChanged}"
                    Height="30"
                    Margin="0,5,0,10"/>

                    <!-- Преподаватель -->
                    <TextBlock Text="Преподаватель"/>

                    <TextBlock Text="(Выберите или введите ФИО)"
                               FontSize="10"
                               Foreground="Gray"
                               Margin="0,0,0,3"/>

                    <ComboBox ItemsSource="{Binding Teachers}"
                              SelectedItem="{Binding SelectedTeacher}"
                              DisplayMemberPath="FullName"
                              IsEditable="True"
                              IsTextSearchEnabled="True"
                              StaysOpenOnEdit="True"
                              Text="{Binding NewTeacherName, UpdateSourceTrigger=PropertyChanged}"
                              Margin="0,5,0,10"/>

                    <!-- Кнопки -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,15,0,0">

                        <Button Content="Отмена"
                                Margin="0,0,10,0"
                                Command="{Binding CloseDialogCommand}"/>

                        <Button Content="Сохранить"
                                Background="ForestGreen"
                                Foreground="White"
                                Command="{Binding AddSubjectCommand}"/>
                    </StackPanel>

                </StackPanel>
            </Border>
        </Grid>

    </Grid>
</UserControl>