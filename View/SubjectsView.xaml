<UserControl x:Class="Journalx3Piska.View.SubjectsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="20">

        <StackPanel>

            <TextBlock Text="Предметы"
                       FontSize="24"
                       FontWeight="Bold"
                       Margin="0 0 0 20"/>

            <DataGrid ItemsSource="{Binding Subjects}"
                      AutoGenerateColumns="False"
                      Height="300">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID"
                                        Binding="{Binding SubjectID}"
                                        Width="100"/>
                    <DataGridTextColumn Header="Название"
                                        Binding="{Binding SubjectName}"
                                        Width="*"/>
                </DataGrid.Columns>

            </DataGrid>

        </StackPanel>

    </Grid>
</UserControl>