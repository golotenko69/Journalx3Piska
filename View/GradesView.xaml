<UserControl x:Class="Journalx3Piska.View.GradesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F6FA">

    <UserControl.Resources>

        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

        <!-- DataGrid -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#F7F9FC"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="RowHeight" Value="40"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <!-- Заголовки -->
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F0F6FF"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>

        <!-- Ячейки -->
        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- Текст слева -->
        <Style x:Key="LeftText" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="10,0,0,0"/>
        </Style>

        <!-- Строки -->
        <Style TargetType="DataGridRow">
            <Setter Property="BorderThickness" Value="0"/>

            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EAF2FF"/>
                </Trigger>

                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#D6EAF8"/>
                    <Setter Property="Foreground" Value="Black"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </UserControl.Resources>

    <Grid>

        <!-- ОСНОВНОЙ КОНТЕНТ -->
        <Grid Margin="20">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <TextBlock Grid.Row="0"
                       Text="Оценки"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="#2C3E50"
                       Margin="0,0,0,10"/>

            <!-- Фильтр + кнопка -->
            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        Margin="0,0,0,15">

                <ComboBox Width="220"
                          ItemsSource="{Binding Subjects}"
                          SelectedItem="{Binding SelectedFilterSubject}"
                          DisplayMemberPath="SubjectName"
                          Margin="0,0,10,0"/>

                <Button Content="Поставить оценку"
                        Width="180"
                        Height="35"
                        Background="#4A90E2"
                        Foreground="White"
                        BorderThickness="0"
                        Command="{Binding OpenGradeDialogCommand}"/>
            </StackPanel>

            <!-- Таблица -->
            <Border Grid.Row="2"
                    Background="White"
                    CornerRadius="12"
                    Padding="15">

                <DataGrid ItemsSource="{Binding Grades}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False">

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="Ученик"
                                            Binding="{Binding StudentName}"
                                            Width="2*"
                                            ElementStyle="{StaticResource LeftText}" />

                        <DataGridTextColumn Header="Предмет"
                                            Binding="{Binding SubjectName}"
                                            Width="2*"
                                            ElementStyle="{StaticResource LeftText}" />

                        <DataGridTextColumn Header="Дата"
                                            Binding="{Binding Date, StringFormat={}{0:dd.MM.yyyy}}"
                                            Width="1.2*"
                                            ElementStyle="{StaticResource LeftText}" />

                        <DataGridTextColumn Header="Оценка"
                                            Binding="{Binding Value}"
                                            Width="1*"
                                            ElementStyle="{StaticResource LeftText}" />

                        <DataGridTextColumn Header="Средний балл"
                                            Binding="{Binding AverageGrade, StringFormat={}{0:F1}}"
                                            Width="1.3*"
                                            ElementStyle="{StaticResource LeftText}" />

                    </DataGrid.Columns>
                </DataGrid>
            </Border>

        </Grid>

        <!-- ДИАЛОГ -->
        <Grid Background="#80000000"
              Visibility="{Binding IsDialogOpen, Converter={StaticResource BoolToVisibility}}"
              Panel.ZIndex="100">

            <Border Width="400"
                    Padding="20"
                    Background="White"
                    CornerRadius="12"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">

                <StackPanel>

                    <TextBlock Text="Выставление оценки"
                               FontSize="18"
                               FontWeight="Bold"
                               Margin="0 0 0 15"/>

                    <TextBlock Text="Ученик"/>
                    <ComboBox ItemsSource="{Binding Students}"
                              SelectedItem="{Binding SelectedStudent}"
                              DisplayMemberPath="FullName"
                              Margin="0,5,0,10"/>

                    <TextBlock Text="Предмет"/>
                    <ComboBox ItemsSource="{Binding SubjectsForAdd}"
                              SelectedItem="{Binding SelectedSubject}"
                              DisplayMemberPath="SubjectName"
                              Margin="0,5,0,10"/>

                    <TextBlock Text="Дата"/>
                    <DatePicker SelectedDate="{Binding SelectedDate}"
                                Margin="0,5,0,10"/>

                    <TextBlock Text="Оценка"/>
                    <ComboBox ItemsSource="{Binding GradesList}"
                              SelectedItem="{Binding SelectedGrade}"
                              Margin="0,5,0,10"/>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,15,0,0">

                        <Button Content="Отмена"
                                Margin="0,0,10,0"
                                Command="{Binding CloseDialogCommand}"/>

                        <Button Content="Сохранить"
                                Background="ForestGreen"
                                Foreground="White"
                                Command="{Binding AddGradeCommand}"/>
                    </StackPanel>

                </StackPanel>
            </Border>
        </Grid>

    </Grid>
</UserControl>