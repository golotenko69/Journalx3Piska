<UserControl x:Class="Journalx3Piska.View.GradesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Journalx3Piska.ViewModels"
                 UseLayoutRounding="True"
                    SnapsToDevicePixels="True"
                    TextOptions.TextFormattingMode="Display"
                    TextOptions.TextRenderingMode="ClearType"
             Background="#F0F2F7">
    

    <UserControl.Resources>
        <vm:EditModeToTitleConverter x:Key="EditModeToTitleConverter"/>
        <vm:EditModeToButtonConverter x:Key="EditModeToButtonConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

        <!-- ================= COMBOBOX FIX ================= -->
        <Style x:Key="RoundedComboBox" TargetType="ComboBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D0D5DD"/>
            <Setter Property="BorderThickness" Value="1"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>

                            <Border x:Name="Border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6">

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition Width="30"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- FIXED -->
                                    <ContentPresenter
                                        Margin="10,0,0,0"
                                        VerticalAlignment="Center"
                                        Content="{TemplateBinding SelectionBoxItem}"
                                        ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                        ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                        ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"/>

                                    <ToggleButton Grid.Column="1"
                                                  IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                                  Background="Transparent"
                                                  BorderThickness="0">
                                        <Path Data="M 0 0 L 4 4 L 8 0 Z"
                                              Fill="#667085"
                                              Width="8"
                                              Height="4"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                    </ToggleButton>
                                </Grid>
                            </Border>

                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   AllowsTransparency="True">

                                <Border Background="White"
                                        BorderBrush="#D0D5DD"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Margin="0,4,0,0">

                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>

                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ТЕКСТ -->
        <Style x:Key="LeftText" TargetType="TextBlock">
            <Setter Property="Margin" Value="10,0,0,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>


        <!-- DataGrid -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#F7F9FC"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="RowHeight" Value="40"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <!-- Заголовки колонок -->
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#4A5E8A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <!-- Ячейки -->
        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>


        <!-- Строки -->
        <Style TargetType="DataGridRow">
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EBF0FA"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#4A5E8A"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Кнопка синяя -->
        <Style x:Key="BlueButton" TargetType="Button">
            <Setter Property="Background" Value="#4A6FD4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="14,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3A5FC4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Кнопка оранжевая -->
        <Style x:Key="OrangeButton" TargetType="Button">
            <Setter Property="Background" Value="#E67E22"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="14,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#D35400"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Кнопка красная -->
        <Style x:Key="RedButton" TargetType="Button">
            <Setter Property="Background" Value="#E53935"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="14,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#C62828"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Кнопка зелёная -->
        <Style x:Key="GreenButton" TargetType="Button">
            <Setter Property="Background" Value="#2E7D32"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="14,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1B5E20"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Label в диалоге -->
        <Style x:Key="DialogLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#4A5E8A"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

    </UserControl.Resources>

    <Grid>

        <!-- ОСНОВНОЙ КОНТЕНТ -->
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <TextBlock Grid.Row="0"
                       Text="Оценки"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="#2C3E50"
                       Margin="0,0,0,14"/>

            <!-- Фильтр + кнопки -->
            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        Margin="0,0,0,15">

                <!-- Стандартный ComboBox без кастомного шаблона -->
                <ComboBox Style="{StaticResource RoundedComboBox}"
                          Width="220"
                          Height="34"
                          ItemsSource="{Binding Subjects}"
                          SelectedItem="{Binding SelectedFilterSubject}"
                          DisplayMemberPath="SubjectName"
                          Foreground="#2C3E50"
                          FontSize="12"
                          Margin="0,0,10,0"
                          VerticalContentAlignment="Center"/>

                <Button Content="Поставить оценку"
                        Width="180"
                        Height="34"
                        Style="{StaticResource BlueButton}"
                        Margin="0,0,8,0"
                        Command="{Binding OpenGradeDialogCommand}"/>

                <Button Content="Изменить оценку"
                        Width="120"
                        Height="34"
                        Style="{StaticResource OrangeButton}"
                        Margin="0,0,8,0"
                        Command="{Binding EditGradeCommand}"/>

                <Button Content="Удалить оценку"
                        Width="120"
                        Height="34"
                        Style="{StaticResource RedButton}"
                        Command="{Binding DeleteGradeCommand}"/>
            </StackPanel>

            <!-- Таблица -->
            <Border Grid.Row="2"
                    Background="White"
                    CornerRadius="12"
                    Padding="0">


                <DataGrid ItemsSource="{Binding Grades}"
                          SelectedItem="{Binding SelectedGradeItem}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Ученик"
                                            Binding="{Binding StudentName}"
                                            Width="2*"
                                            ElementStyle="{StaticResource LeftText}"/>
                        <DataGridTextColumn Header="Предмет"
                                            Binding="{Binding SubjectName}"
                                            Width="2*"
                                            ElementStyle="{StaticResource LeftText}"/>
                        <DataGridTextColumn Header="Дата"
                                            Binding="{Binding Date, StringFormat={}{0:dd.MM.yyyy}}"
                                            Width="1.2*"
                                            ElementStyle="{StaticResource LeftText}"/>
                        <DataGridTextColumn Header="Оценка"
                                            Binding="{Binding Value}"
                                            Width="1*"
                                            ElementStyle="{StaticResource LeftText}"/>
                        <DataGridTextColumn Header="Средний балл"
                                            Binding="{Binding AverageGrade, StringFormat={}{0:F1}}"
                                            Width="1.3*"
                                            ElementStyle="{StaticResource LeftText}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

        </Grid>

        <!-- ДИАЛОГ -->
        <Grid Background="#70263238"
              Visibility="{Binding IsDialogOpen, Converter={StaticResource BoolToVisibility}}"
              Panel.ZIndex="100">

            <Border Width="420"
                    Background="White"
                    CornerRadius="12"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" ShadowDepth="6" Opacity="0.25" Color="#000000"/>
                </Border.Effect>

                <Grid>

                    <!-- Синяя шапка диалога -->
                    <Border Background="#4A5E8A"
                            CornerRadius="12,12,0,0"
                            Height="52"
                            VerticalAlignment="Top">
                        <Grid Margin="20,0">
                            <TextBlock FontSize="16"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       VerticalAlignment="Center"
                                       Text="{Binding IsEditMode, Converter={StaticResource EditModeToTitleConverter}}"/>

                            <!-- Крестик -->
                            <Button Width="28"
                                    Height="28"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Foreground="White"
                                    BorderThickness="0"
                                    FontSize="12"
                                    FontWeight="Bold"
                                    Cursor="Hand"
                                    Command="{Binding CloseDialogCommand}">
                                <Button.Content>
                                    <TextBlock Text="✕"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Button.Content>
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="#E53935"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            CornerRadius="4">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#C62828"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Тело диалога -->
                    <Grid Margin="20,68,20,20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Ученик -->
                        <StackPanel Grid.Row="0" Margin="0,0,0,12">
                            <TextBlock Text="Ученик" Style="{StaticResource DialogLabel}"/>
                            <ComboBox Style="{StaticResource RoundedComboBox}"
                              ItemsSource="{Binding Students}"
                              SelectedItem="{Binding SelectedStudent}"
                              DisplayMemberPath="FullName"/>
                        </StackPanel>

                        <!-- Предмет -->
                        <StackPanel Grid.Row="1" Margin="0,0,0,12">
                            <TextBlock Text="Предмет" Style="{StaticResource DialogLabel}"/>
                            <ComboBox Style="{StaticResource RoundedComboBox}"
                              ItemsSource="{Binding SubjectsForAdd}"
                              SelectedItem="{Binding SelectedSubject}"
                              DisplayMemberPath="SubjectName"/>
                        </StackPanel>

                        <!-- Дата -->
                        <StackPanel Grid.Row="2" Margin="0,0,0,12">
                            <TextBlock Text="Дата" Style="{StaticResource DialogLabel}"/>
                            <DatePicker SelectedDate="{Binding SelectedDate}"
                                        Height="34"
                                        FontSize="12"
                                        VerticalContentAlignment="Center"/>
                        </StackPanel>

                        <!-- Оценка -->
                        <StackPanel Grid.Row="3" Margin="0,0,0,20">
                            <TextBlock Text="Оценка" Style="{StaticResource DialogLabel}"/>
                            <ComboBox Style="{StaticResource RoundedComboBox}"
                                      ItemsSource="{Binding GradesList}"
                                      SelectedItem="{Binding SelectedGrade}"
                                      Height="34"
                                      FontSize="12"
                                      VerticalContentAlignment="Center"/>
                        </StackPanel>

                        <!-- Кнопка -->
                        <StackPanel Grid.Row="4"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right">
                            <Button Content="{Binding IsEditMode, Converter={StaticResource EditModeToButtonConverter}}"
                                    Width="379"
                                    Height="36"
                                    Style="{StaticResource GreenButton}"
                                    Command="{Binding SaveGradeCommand}"/>
                        </StackPanel>

                    </Grid>
                </Grid>
            </Border>
        </Grid>

    </Grid>
</UserControl>